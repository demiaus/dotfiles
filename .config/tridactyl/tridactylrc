"
" ~/.config/tridactyl/tridactylrc
"

" Make sure that unsetting an option here also resets it in the running session
sanitise tridactyllocal tridactylsync
set profiledir "7elx7fhb.default-release"

" Rosé Pine
" colourscheme --url https://gitlab.com/krumeluu/dotfiles/-/raw/main/.config/tridactyl/themes/rose-pine.css rose-pine
colourscheme rose-pine
set newtab about:blank

" Hintchars close to homerow, please
set hintfiltermode vimperator
set hintchars asdfjklweruio

" Make t open the selection with tabopen
bind --mode=visual t composite js document.getSelection().toString() | fillcmdline tabopen

" Make search great again
bind / fillcmdline find
bind ? fillcmdline find -?
bind n findnext 1
bind N findnext 1 -?
bind <Space>s nohlsearch

bind   --mode=ex <C-a> text.beginning_of_line
unbind --mode=ex <C-c>

" Don't need no new windows (Detach one if you must)
unbind w
unbind W
bind gd tabdetach
bind gD composite tabduplicate; tabdetach

" I'm bookmarking way too many pages by accident
unbind a
unbind A
bind b current_url bmark
bind B bmark
bind t fillcmdline tab

" Reverse tabmove to make sense with sidepane tabs and qutebrowser
bind J tabnext
bind K tabprev
bind o fillcmdline open
bind O fillcmdline tabopen

" Youtube's a bitch, but these seem to work
unbindurl ^https://www\.youtube\.com/watch\?v=.*$ f
bindurl   ^https://www\.youtube\.com/watch\?v=.*$ j !s xdotool key Left
bindurl   ^https://www\.youtube\.com/watch\?v=.*$ l !s xdotool key Right
" Move frame by frame
unbindurl ^https://www\.youtube\.com/watch\?v=.*$ ,
unbindurl ^https://www\.youtube\.com/watch\?v=.*$ .
" Stop/resume
bindurl   ^https://www\.youtube\.com/watch\?v=.*$ <Space> !s xdotool key k
unbindurl ^https://www\.youtube\.com/watch\?v=.*$ k

autocmd DocStart https://10fastfingers.com/ mode ignore
autocmd DocStart https://monkeytype.com/    mode ignore

set hintdelay 100
set smoothscroll true

" Use st to open vim
set editorcmd st -e vim

" " Hide ignore-mode indicator
" set modeindicatormodes.ignore false
" " Hide normal-mode indicator
" set modeindicatormodes.normal false
" " Actually, hide all modeindicators
" set modeindicator false

