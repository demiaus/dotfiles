# 
# ~/.config/tridactyl/tridactylrc
# 

" Make sure that unsetting an option here also resets it in the running session
sanitise tridactyllocal tridactylsync

" Rosé Pine
colourscheme --url https://gitlab.com/krumeluu/dotfiles/-/raw/main/.config/tridactyl/themes/base16-rose-pine.css rose-pine
set newtab about:blank

" Make t open the selection with tabopen
bind --mode=visual t composite js document.getSelection().toString() | fillcmdline tabopen

bind gd tabdetach
bind gD composite tabduplicate; tabdetach

" Make search great again
bind / fillcmdline find
bind ? fillcmdline find -?
bind n findnext 1
bind N findnext -1
bind <Space><Space> nohlsearch

bind   --mode=ex <C-a> text.beginning_of_line
unbind --mode=ex <C-c>

" Don't need no new windows (Detach one if you must)
unbind w
unbind W

unbindurl youtube.com <Space>
unbindurl youtube.com --mode=normal f
unbindurl youtube.com --mode=normal j
unbindurl youtube.com --mode=normal k
unbindurl youtube.com --mode=normal l
unbindurl youtube.com --mode=normal ,
unbindurl youtube.com --mode=normal .
bindurl   youtube.com j !s xdotool key Left
bindurl   youtube.com l !s xdotool key Right

set hintdelay 100
set smoothscroll true

" Use alacritty to open vvm
set editorcmd alacritty -e vim

" Hide ignore-mode indicator
set modeindicatormodes.ignore false
Ami
Kajan
